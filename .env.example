# IdeaGraph — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# ─── Backend (api/) ───────────────────────────────────────────────────────────

# Your Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Port for the Express API server (default: 3001)
PORT=3001

# ─── Frontend (src/) ──────────────────────────────────────────────────────────
# All frontend env vars must start with VITE_

# URL of the backend API
# Development: http://localhost:3001
# Production: your Railway URL, e.g. https://ideagraph-api.railway.app
VITE_API_URL=http://localhost:3001

# ─── GitHub Actions (set in repo Settings > Secrets) ─────────────────────────
# VITE_API_URL — your production Railway URL
# (ANTHROPIC_API_KEY is only needed on the backend, not in GitHub Actions)

# ─── Dev flags ────────────────────────────────────────────────────────────────
# Set to 'true' to skip the API and use hardcoded seed data (no API key needed)
VITE_USE_SEED=false
